# macOS
.DS_Store

# Python virtual environment
.venv/
__pycache__/
*.pyc

# Environment / credentials
.env
.env.*
*.secret

# Source data (contains personal info: emails, birth dates, etc.)
**/data/sources/*.xlsx
# organizers-delegates.txt is public info — tracked

# Generated data
**/data/outputs/volunteers.json
# score_takers.txt and scramble_report.txt are public info — tracked
# volunteer_properties.cs contains public WCA IDs — tracked

# Generated reports HTML
**/reports/html/*
!**/reports/html/.gitkeep

# WCIF backups (contain personal data)
**/backups/*
!**/backups/.gitkeep

# WCIF cache (contains personal data)
.wcif_cache/

# Node modules (compscript has its own)
node_modules/

# Lock files managed per project
# uv.lock is tracked (committed)

# Generated DEV / pre-deploy WCIF outputs (ephemeral)
**/data/outputs/staff_dev_v2.json
**/data/outputs/staff_only_dev.json
**/data/outputs/_predeploy_validate.json
